# ┌──────────────────────────────────────────────────────────────────────┐
# │  Copepod Backend Environment Configuration                         │
# │  Copy to .env and fill in your values                              │
# └──────────────────────────────────────────────────────────────────────┘

# ── GitHub OAuth App ─────────────────────────────────────────────────
# Register at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── Google Gemini (AI Studio) ────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Powers both Cognee entity extraction AND Studio answer formatting
GEMINI_API_KEY=your_gemini_api_key

# ── Security Keys ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_64_char_hex_key_here
JWT_SECRET=your_jwt_secret_here
WEBHOOK_SECRET=your_webhook_secret_here

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./copepod.db

# ── Cognee Configuration (all zero cost) ─────────────────────────────
COGNEE_LLM_MODEL=gemini/gemini-3.5-flash
COGNEE_EMBEDDING_PROVIDER=fastembed
COGNEE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
COGNEE_GRAPH_DB=kuzu
COGNEE_VECTOR_DB=lancedb

# ── Server ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
