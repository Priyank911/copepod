# ┌──────────────────────────────────────────────────────────────────────┐
# │  Copepod Backend Environment Configuration                         │
# │  Copy to .env and fill in your values                              │
# └──────────────────────────────────────────────────────────────────────┘

# ── GitHub OAuth App ─────────────────────────────────────────────────
# Register at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Groq API Key (free) ─────────────────────────────────────────────
# Get from: https://console.groq.com
# Powers both Cognee entity extraction AND Studio answer formatting
GROQ_API_KEY=gsk_your_groq_key

# ── Security Keys ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=replace_with_64_hex_chars_for_aes256
JWT_SECRET=replace_with_random_string
WEBHOOK_SECRET=replace_with_random_string

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./copepod.db

# ── Cognee Configuration (all zero cost) ─────────────────────────────
COGNEE_LLM_MODEL=groq/llama-3.3-70b-versatile
COGNEE_EMBEDDING_PROVIDER=fastembed
COGNEE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
COGNEE_GRAPH_DB=kuzu
COGNEE_VECTOR_DB=lancedb

# ── Server ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
